{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FinSEO API",
  "colors": {
    "primary": "#0eca7b",
    "light": "#0eca7b",
    "dark": "#0a9956"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.finseo.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.finseo.ai/settings/api"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "authentication", "rate-limits"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Projects",
            "pages": ["api-reference/projects"]
          },
          {
            "group": "Prompts",
            "pages": ["api-reference/prompts"]
          },
          {
            "group": "Metrics",
            "pages": ["api-reference/metrics"]
          },
          {
            "group": "Competitors",
            "pages": ["api-reference/competitors"]
          },
          {
            "group": "Sources",
            "pages": ["api-reference/sources"]
          },
          {
            "group": "Export",
            "pages": ["api-reference/export"]
          }
        ]
      },
      {
        "tab": "MCP",
        "groups": [
          {
            "group": "MCP Integration",
            "pages": ["mcp/overview", "mcp/claude-desktop", "mcp/cursor"]
          }
        ]
      }
    ]
  },
  "openapi": "openapi.yaml",
  "api": {
    "baseUrl": "https://app.finseo.ai",
    "auth": {
      "method": "bearer"
    }
  },
  "footer": {
    "socials": {
      "website": "https://finseo.ai",
      "linkedin": "https://linkedin.com/company/finseo"
    }
  }
}
